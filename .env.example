# Copy this file to .env and fill in your key. .env is git-ignored.
ANTHROPIC_API_KEY=

# Optional: point the SDK at a non-official / proxy endpoint. Leave this line
# commented out to use the official API (https://api.anthropic.com).
# Note: an empty value (ANTHROPIC_BASE_URL=) breaks requests — comment it out
# instead of leaving it blank.
# ANTHROPIC_BASE_URL=https://your-proxy.example.com

# Optional: override the model. Leave commented out to use the default
# (claude-sonnet-4-6). An empty / whitespace-only value falls back to the default.
# ANTHROPIC_MODEL=claude-opus-4-8
